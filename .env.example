# Server
PORT=3000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=reki_db

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Manchester City Config
DEFAULT_CITY=Manchester
DEFAULT_LAT=53.4808
DEFAULT_LNG=-2.2426

# Weather API (OpenWeatherMap - optional for MVP)
WEATHER_API_KEY=your-openweathermap-api-key

# Error Tracking (Sentry - optional)
SENTRY_DSN=your-sentry-dsn-url

# Firebase Push Notifications (optional for dev - mock mode if missing)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Apple Wallet (Phase 1 - optional)
APPLE_PASS_TYPE_ID=pass.com.reki.offers
APPLE_TEAM_ID=your-apple-team-id
